# Backend Port Config
PORT=5000

# MongoDB Connection String
# For running locally on host machine:
# MONGO_URI=mongodb://admin:password123@localhost:27017/aceplay?authSource=admin
# For running inside Docker container (local mongodb service):
MONGO_URI=mongodb://admin:password123@mongodb:27017/aceplay?authSource=admin

# Application environment configuration
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Superadmin Configuration
# Comma-separated emails that register/login as superadmin (can view Activity Logs)
SUPERADMIN_EMAILS=imalshafdo4@gmail.com
superadmin_password=SuperAdminPassword123!

# Frontend Public API URL (Used by Nuxt 4 Admin Panel)
# This is used by the browser, so it should point to localhost (from host perspective)
NUXT_PUBLIC_API_BASE=http://localhost:5000/api/admin
